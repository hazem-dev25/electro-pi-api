# MongoDB connection string
DB_URL=mongodb://localhost:27017/electro-pi

# Server configuration
PORT=3000
MODE=dev

# JWT secrets
ADMIN_JWT=your_admin_access_secret
USER_JWT=your_user_access_secret
REFRESH_ADMIN_JWT=your_admin_refresh_secret
REFRESH_USER_JWT=your_user_refresh_secret

# Bcrypt salt rounds
SALT=10

# Email sending credentials
APP_EMAIL=your.email@gmail.com
APP_PASSWORD=your-email-password

# Redis URL (optional)
REDIS_URL=redis://localhost:6379
